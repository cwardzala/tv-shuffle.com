---
layout: 'layouts/base.njk'
---

<nav class="navbar">
    <div class="navbar-inner">
        <a href="/" class="logo">
            <img src="./img/tvs-logo-960.png" alt="TV Shuffle" />
            <span class="logo-text">TV Shuffle</span>
        </a>
    </div>
</nav>

<section class="hero">
    <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        Now on iPhone &amp; iPad
    </div>
    <h1 class="hero-title">
        Can't decide?<br/>
        <span class="hero-title-accent">Let us pick.</span>
    </h1>
    <p class="hero-subtitle">
        TV Shuffle randomly selects episodes from your favorite shows. Perfect for binge rewatches or discovering new episodes from series you love.
    </p>
    <a href="https://apps.apple.com/us/app/tv-shuffle/id6737577166" target="_blank" rel="noopener noreferrer" class="btn-primary">
        <i class="bi-apple"></i>
        Download on App Store
    </a>
    <img src="./img/screens/FramedScreenshot_0.png" alt="TV Shuffle App" class="hero-image" />
</section>

<section class="features">
    <div class="features-inner">
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-search"></i>
                </div>
                <h3>Search Shows</h3>
                <p>Find any TV show in seconds. Add favorites to your library for quick access anytime.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-shuffle"></i>
                </div>
                <h3>Surprise Me!</h3>
                <p>Tap a show and get a random episode. See snapshots, titles, descriptions, and where to watch.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-grid-3x3"></i>
                </div>
                <h3>Custom Layouts</h3>
                <p>Choose between grid or list view. Sort your library your way for the perfect experience.</p>
            </div>
        </div>
    </div>
</section>

<section class="whats-new">
    <div class="whats-new-inner">
        <div class="whats-new-label">What's New</div>
        <h2>Fresh updates, just for you</h2>
        <div class="whats-new-grid">
            <div class="whats-new-card">
                <div class="whats-new-icon">
                    <i class="bi bi-circle-half"></i>
                </div>
                <h3>Light &amp; Dark Mode</h3>
                <p>Looks great day or night — TV Shuffle follows your system appearance automatically.</p>
            </div>
            <div class="whats-new-card">
                <div class="whats-new-icon">
                    <i class="bi bi-tablet"></i>
                </div>
                <h3>iPad Support</h3>
                <p>A fully optimized layout for iPad, with a wider grid and more shows at a glance.</p>
            </div>
            <div class="whats-new-card">
                <div class="whats-new-icon">
                    <i class="bi bi-fire"></i>
                </div>
                <h3>Popular Right Now</h3>
                <p>Discover what everyone's watching and add trending shows to your library instantly.</p>
            </div>
        </div>
    </div>
</section>

<section class="screenshot-section">
    <div class="screenshot-section-inner">
        <h2>See it in action</h2>
        <p class="lead">Beautiful, simple, and easy to use</p>
        <div class="screenshot-device-group">
            <div class="screenshot-device-label"><i class="bi bi-phone"></i> iPhone</div>
            <div class="screenshot-grid">
                <img src="./img/screens/FramedScreenshot_0.png" alt="My Shows library" class="screenshot-img" />
                <img src="./img/screens/FramedScreenshot_1.png" alt="Add shows" class="screenshot-img" />
                <img src="./img/screens/FramedScreenshot_2.png" alt="Episode detail" class="screenshot-img" />
            </div>
        </div>
        <div class="screenshot-device-group">
            <div class="screenshot-device-label"><i class="bi bi-tablet"></i> iPad</div>
            <div class="screenshot-grid">
                <img src="./img/screens/FramedScreenshot_3.png" alt="My Shows library on iPad" class="screenshot-img" />
                <img src="./img/screens/FramedScreenshot_4.png" alt="Add shows on iPad" class="screenshot-img" />
                <img src="./img/screens/FramedScreenshot_5.png" alt="Episode detail on iPad" class="screenshot-img" />
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="cta-section-inner">
        <h2>Ready to shuffle?</h2>
        <p>Download TV Shuffle today and never stress about what to watch next.</p>
        <a href="https://apps.apple.com/us/app/tv-shuffle/id6737577166" target="_blank" rel="noopener noreferrer" class="btn-primary">
            <i class="bi-apple"></i>
            Download on App Store
        </a>
    </div>
</section>
